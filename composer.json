            "name": "JanHuang",
            "email": "384099566@qq.com"
        }
    ],
    "require": {
        "PHP": ">=8.2",
        "symfony/cache": "^8.0"
    },
    "require-dev": {
        "symfony/console": "^8.0",
        "predis/predis": "^3.0",
        "phpunit/phpunit": "^9.6",
        "fastd/container": "^8.0",
        "fastd/http": "^8.0",
        "fastd/middleware": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "FastD\\Cache\\": "src"
        },
        "files": [
            "helpers.php"
        ]
    },
    "autoload-dev": {
        "tests": "tests"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-clover=build/logs/clover.xml --coverage-html=build/coverage",
        "test-coverage-clover": "phpunit --coverage-clover=build/logs/clover.xml"
    }
}
